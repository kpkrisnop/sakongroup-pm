# MQTT Broker Details
MQTT_BROKER = "your_broker_host"
MQTT_PORT = 1883
MQTT_USER = "your_username"
MQTT_PASSWORD = "your_password"

# HA Topic Patterns
# HA Statestream usually publishes to: base_topic/domain/object_id/state
MQTT_TOPIC_PM25=sakongrouppm/sensor/+/state

# API Settings
API_PORT=8000
RATE_LIMIT=60/minute
